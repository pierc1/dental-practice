    },
    "title": {
      "type": "string",
      "description": "Professional title (e.g., DDS, DMD)"
    },
    "specialty": {
      "type": "string",
      "description": "Area of specialization"
    },
    "bio": {
      "type": "string",
      "description": "Professional biography"
    },
    "photo_url": {
      "type": "string",
      "description": "Profile photo URL"
    },
    "education": {
      "type": "string",
      "description": "Educational background"
    },
    "years_experience": {
      "type": "number",
      "description": "Years of practice"
    },
    "available_days": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ]
      },
      "description": "Days available for appointments"
